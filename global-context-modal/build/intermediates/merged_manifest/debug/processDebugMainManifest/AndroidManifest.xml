<?xml version="1.0" encoding="utf-8"?>
<!-- 2026-07-05 — Companion global context modal + input coordinator (fail-open SPOF relief). -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.solar.launcher.globalcontext"
    android:sharedUserId="android.uid.system"
    android:versionCode="1"
    android:versionName="1.0.0" >

    <uses-sdk
        android:minSdkVersion="17"
        android:targetSdkVersion="35" />

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.GET_TASKS" />
    <!-- 2026-07-10 — Theme sidecars on MicroSD / internal (.solar/theme-*.json + selection PNG). -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!-- 2026-07-08 — ChipOverlayHost Wi‑Fi / BT / brightness tiers. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />
    <!-- 2026-07-08 — Debug ingest to host via adb reverse; remove with AgentDebugLog. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="com.solar.launcher.permission.OVERLAY_TRIGGER" />

    <permission
        android:name="com.solar.launcher.permission.OVERLAY_TRIGGER"
        android:protectionLevel="signatureOrSystem" />

    <application
        android:allowBackup="false"
        android:debuggable="true"
        android:extractNativeLibs="true"
        android:icon="@android:drawable/ic_menu_info_details"
        android:label="@string/companion_app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault" >
        <service
            android:name="com.solar.launcher.globalcontext.GlobalContextOverlayService"
            android:exported="true"
            android:process=":overlay" />

        <!--
             2026-07-10 — Same process as overlay shell so static KeyGate handler is live.
             Xposed prefers broadcast for high-frequency wheel; startService remains fallback.
        -->
        <receiver
            android:name="com.solar.launcher.globalcontext.CompanionOverlayKeyReceiver"
            android:exported="true"
            android:process=":overlay" >
            <intent-filter>
                <action android:name="com.solar.launcher.action.OVERLAY_KEY" />
            </intent-filter>
        </receiver>

        <service
            android:name="com.solar.launcher.globalcontext.RescueHoldService"
            android:exported="true"
            android:process=":hold" />
        <service
            android:name="com.solar.launcher.globalcontext.GlobalInputCoordinatorService"
            android:exported="true" />
        <service
            android:name="com.solar.launcher.globalcontext.CompanionImeOverlayService"
            android:exported="false"
            android:process=":overlay" />
        <service
            android:name="com.solar.launcher.globalcontext.SolarCrashWatchdog"
            android:exported="false"
            android:process=":watchdog" />

        <receiver
            android:name="com.solar.launcher.globalcontext.CompanionBootReceiver"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <activity
            android:name="com.solar.launcher.globalcontext.EmergencyRecoveryActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
    </application>

</manifest>