#!/system/bin/sh
# Rockbox native system() helper on Y2 — runs am/monkey as root via su.
# Invoked from patched librockbox.so (same-length string replacements).

# #region agent log
DEBUG_LOG="${SOLAR_DEBUG_LOG:-/data/local/tmp/debug-d58bf0.log}"
touch "$DEBUG_LOG" 2>/dev/null || true
chmod 666 "$DEBUG_LOG" 2>/dev/null || true
debug_log() {
    hyp="$1"; loc="$2"; msg="$3"; arg="$4"; extra="$5"
    ts=$(date +%s)000
    printf '{"sessionId":"d58bf0","hypothesisId":"%s","location":"%s","message":"%s","data":{"arg":"%s","extra":"%s"},"timestamp":%s}\n' \
        "$hyp" "$loc" "$msg" "$arg" "$extra" >> "$DEBUG_LOG" 2>/dev/null || true
}
# #endregion

ACTION="${1:-}"
# #region agent log
debug_log "A" "solar-rb-launch:entry" "launch request" "$ACTION" ""
# #endregion

case "$ACTION" in
    settings)
        /system/xbin/su -c 'am start -a android.settings.SETTINGS'
        ;;
    bluetooth-settings)
        /system/xbin/su -c 'am start -a android.settings.BLUETOOTH_SETTINGS'
        ;;
    fm-radio-activity-xx)
        /system/xbin/su -c 'am start -n com.mediatek.FMRadio/.FMRadioActivity'
        ;;
    rockbox-restart-monkey-launch0)
        _disabled=$(pm list packages -d org.rockbox 2>/dev/null)
        _target=$(getprop persist.solar.home.target solar)
        if [ -n "$_disabled" ] || [ "$_target" = "solar" ]; then
            exit 0
        fi
        /system/xbin/su -c 'monkey -p org.rockbox -c android.intent.category.LAUNCHER 1'
        ;;
    *)
        # #region agent log
        debug_log "A" "solar-rb-launch:unknown" "unknown action" "$ACTION" ""
        # #endregion
        exit 1
        ;;
esac
RC=$?
# #region agent log
debug_log "A" "solar-rb-launch:exit" "launch finished" "$ACTION" "rc=$RC"
# #endregion
exit "$RC"
