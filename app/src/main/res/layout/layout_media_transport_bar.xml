<?xml version="1.0" encoding="utf-8"?>
<!-- 2026-07-11 — Tall bottom band; padTop drops scrub into chrome (was floating mid-band). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/transport_bar_root"
    android:layout_width="match_parent"
    android:layout_height="@dimen/y1_player_transport_height"
    android:orientation="vertical"
    android:gravity="bottom"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:paddingTop="16dp"
    android:paddingBottom="2dp">

    <TextView
        android:id="@+id/transport_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingBottom="4dp"
        android:singleLine="true"
        android:text="@string/context_hold_back_hint"
        android:textSize="12sp"
        android:visibility="gone" />
    <!-- 2026-07-11 — Default = Y1 Back-only; MediaTransportBar swaps to context_hold_back_or_power_hint on Y2. -->

    <!-- 2026-07-06 — scrub row grows when FM tune shows MHz above the knob circle. -->
    <LinearLayout
        android:id="@+id/transport_scrub_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/y1_player_progress_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="10dp"
        android:paddingRight="10dp">

        <FrameLayout
            android:layout_width="77dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical">

            <TextView
                android:id="@+id/transport_time_current"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:singleLine="true"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/transport_volume_icon"
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/context_quick_volume"
                android:scaleType="centerInside"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Center column: live MHz above scrub track (FM tune) + progress knob. -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/transport_scrub_freq"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingBottom="2dp"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/transport_progress_track"
                android:layout_width="match_parent"
                android:layout_height="16dp">

                <ProgressBar
                    android:id="@+id/transport_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_gravity="center_vertical"
                    android:max="100"
                    android:progress="0" />

                <ProgressBar
                    android:id="@+id/transport_volume_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_gravity="center_vertical"
                    android:max="15"
                    android:progress="0"
                    android:visibility="gone" />

                <View
                    android:id="@+id/transport_scrub_marker"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="center_vertical"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/transport_time_total"
            android:layout_width="77dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:singleLine="true"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
