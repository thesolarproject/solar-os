<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:background="#000000">

    <!-- Double-buffered wallpaper stack — animates in lockstep with screen transitions. -->
    <FrameLayout
        android:id="@+id/backdrop_stack"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:id="@+id/backdrop_out"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/iv_main_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="#000000" />

            <ImageView
                android:id="@+id/iv_screen_mask"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/backdrop_in"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iv_main_bg_in"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="#000000" />

            <ImageView
                android:id="@+id/iv_screen_mask_in"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />
        </FrameLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/layout_main_menu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000"
        android:visibility="visible">

        <FrameLayout
            android:id="@+id/menu_list_host"
            android:layout_width="@dimen/y1_menu_width"
            android:layout_height="@dimen/y1_menu_height"
            android:layout_marginLeft="@dimen/y1_menu_left"
            android:layout_marginTop="@dimen/y1_status_bar_height"
            android:clipChildren="true">

            <com.solar.launcher.Y1SafeScrollView
                android:id="@+id/menu_scroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/container_home_menu_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </com.solar.launcher.Y1SafeScrollView>
        </FrameLayout>

        <ImageView
            android:id="@+id/iv_menu_preview"
            android:layout_width="@dimen/y1_preview_width"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="@dimen/y1_preview_margin_top"
            android:layout_marginRight="@dimen/y1_preview_margin_right"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/music_circle" />

        <TextView
            android:id="@+id/tv_menu_preview_title"
            android:layout_width="@dimen/y1_preview_width"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="250dp"
            android:layout_marginRight="@dimen/y1_preview_margin_right"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_menu_preview_artist"
            android:layout_width="@dimen/y1_preview_width"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="272dp"
            android:layout_marginRight="@dimen/y1_preview_margin_right"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:gravity="center"
            android:singleLine="true"
            android:visibility="gone" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/layout_browser_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000"
        android:paddingLeft="10dp"
        android:paddingTop="@dimen/y1_status_bar_height"
        android:paddingRight="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- 2026-07-11: path trail under status bar; MainActivity gate keeps GONE. Reversal: SHOW_BROWSER_PATH_BREADCRUMB. -->
            <TextView
                android:id="@+id/tv_browser_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:singleLine="true"
                android:text="@string/common_path_music"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:visibility="gone" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <FrameLayout
                    android:id="@+id/browser_list_host"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <com.solar.launcher.Y1SafeScrollView
                        android:id="@+id/scroll_view_browser"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fillViewport="true">

                        <LinearLayout
                            android:id="@+id/container_browser_items"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </com.solar.launcher.Y1SafeScrollView>
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/podcast_preview_pane"
                    android:layout_width="@dimen/y1_podcast_preview_width"
                    android:layout_height="match_parent"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="@dimen/y1_settings_preview_title_top"
                    android:layout_marginRight="@dimen/y1_settings_preview_margin_right"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/iv_podcast_preview_art"
                        android:layout_width="@dimen/y1_podcast_preview_width"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:maxHeight="@dimen/y1_podcast_preview_art_max"
                        android:scaleType="fitCenter"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_podcast_preview_show"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:ellipsize="marquee"
                        android:gravity="center"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:singleLine="true"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_podcast_preview_episode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:ellipsize="marquee"
                        android:gravity="center"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:singleLine="true"
                        android:textColor="#AAAAAA"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_podcast_preview_meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/layout_settings_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/settings_menu_host"
            android:layout_width="@dimen/y1_settings_menu_width"
            android:layout_height="@dimen/y1_settings_menu_height"
            android:layout_marginLeft="@dimen/y1_menu_left"
            android:layout_marginTop="@dimen/y1_status_bar_height"
            android:clipChildren="true">

            <com.solar.launcher.Y1SafeScrollView
                android:id="@+id/settings_list_scroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/container_settings_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </com.solar.launcher.Y1SafeScrollView>

            <LinearLayout
                android:id="@+id/soulseek_conversation_host"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <Button
                    android:id="@+id/btn_conversation_back"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/soulseek_back_messages" />

                <TextView
                    android:id="@+id/tv_conversation_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="marquee"
                    android:gravity="center"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:paddingLeft="10dp"
                    android:paddingTop="6dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="6dp"
                    android:singleLine="true"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.solar.launcher.Y1SafeListView
                    android:id="@+id/list_conversation_thread"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:divider="@null"
                    android:scrollbars="none" />
            </LinearLayout>

            <!-- Fixed chrome (Back / New message) stays above the scrolling peer list — wheel always reaches it. -->
            <LinearLayout
                android:id="@+id/reach_browse_host"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/reach_browse_chrome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <com.solar.launcher.Y1SafeListView
                    android:id="@+id/list_reach_browse"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:divider="@null"
                    android:scrollbars="none" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/settings_preview_pane"
            android:layout_width="@dimen/y1_preview_width"
            android:layout_height="match_parent"
            android:layout_gravity="top|end"
            android:layout_marginTop="@dimen/y1_settings_preview_title_top"
            android:layout_marginRight="@dimen/y1_settings_preview_margin_right"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_settings_preview_icon"
                android:layout_width="@dimen/y1_preview_width"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:maxHeight="@dimen/y1_setting_icon_max"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_settings_preview_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.solar.launcher.StoragePieView
                android:id="@+id/storage_pie_view"
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_marginTop="12dp"
                android:visibility="gone" />

            <ScrollView
                android:id="@+id/settings_preview_state_scroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:scrollbars="none">

                <TextView
                    android:id="@+id/tv_settings_preview_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal|top"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
            </ScrollView>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/theme_gallery_interstitial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#E6000000"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingTop="@dimen/y1_settings_preview_title_top"
                android:paddingRight="16dp">

                <ImageView
                    android:id="@+id/iv_theme_interstitial_cover"
                    android:layout_width="@dimen/y1_preview_width"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:maxHeight="@dimen/y1_setting_icon_max"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_theme_interstitial_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:ellipsize="marquee"
                    android:gravity="center"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:singleLine="true"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_theme_interstitial_author"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:singleLine="true"
                    android:textColor="#AAAAAA"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btn_theme_interstitial_download"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/y1_menu_item_height"
                    android:layout_marginTop="16dp"
                    android:background="@android:color/transparent"
                    android:focusable="true"
                    android:text="@string/common_download"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btn_theme_interstitial_back"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/y1_menu_item_height"
                    android:layout_marginTop="4dp"
                    android:background="@android:color/transparent"
                    android:focusable="true"
                    android:text="@string/common_back"
                    android:textColor="#AAAAAA" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_bluetooth_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="@dimen/y1_status_bar_height"
        android:paddingBottom="10dp"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:background="#00000000"
        android:visibility="gone">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/bluetooth_scan_header" android:textColor="#BBFFFFFF" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="6dp" android:visibility="gone"/>
        <Button android:id="@+id/btn_scan_bt" android:layout_width="match_parent" android:layout_height="@dimen/y1_menu_item_height" android:text="@string/bluetooth_scan_devices" android:background="@android:color/transparent" android:focusable="true"/>
        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true" android:layout_marginTop="5dp">
            <LinearLayout android:id="@+id/container_bt_items" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_wifi_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="@dimen/y1_status_bar_height"
        android:paddingBottom="10dp"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:background="#00000000"
        android:visibility="gone">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/wifi_networks_header" android:textColor="#BBFFFFFF" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="6dp" android:visibility="gone"/>
        <Button android:id="@+id/btn_scan_wifi" android:layout_width="match_parent" android:layout_height="@dimen/y1_menu_item_height" android:text="@string/wifi_scan_networks" android:background="@android:color/transparent" android:focusable="true"/>
        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true" android:layout_marginTop="5dp">
            <LinearLayout android:id="@+id/container_wifi_items" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_wifi_keyboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal|top"
        android:paddingTop="@dimen/y1_status_bar_height"
        android:paddingLeft="15dp"
        android:paddingRight="15dp"
        android:paddingBottom="8dp"
        android:background="#00000000"
        android:visibility="gone">
        <TextView android:id="@+id/tv_keyboard_ssid" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Target: My_Home_Wifi" android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
        <TextView android:id="@+id/tv_keyboard_input" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="@dimen/y1_menu_item_height" android:text="" android:textSize="@dimen/y1_menu_text_size" android:textStyle="bold" android:gravity="center" android:layout_marginTop="8dp" android:layout_marginBottom="10dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
            <TextView android:id="@+id/tv_key_pprev" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="a" android:textSize="@dimen/y1_menu_text_size"/>
            <TextView android:id="@+id/tv_key_prev" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="b" android:textSize="@dimen/y1_menu_text_size"/>
            <TextView android:id="@+id/tv_key_current" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="c" android:textSize="@dimen/y1_menu_text_size" android:textStyle="bold"/>
            <TextView android:id="@+id/tv_key_next" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="d" android:textSize="@dimen/y1_menu_text_size"/>
            <TextView android:id="@+id/tv_key_nnext" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="e" android:textSize="@dimen/y1_menu_text_size"/>
        </LinearLayout>
        <!-- 2026-07-18 — Padded legend so Back ImageSpan never clips; three glyph rows from HardwareButtonGlyph. -->
        <TextView android:id="@+id/tv_keyboard_hint" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_horizontal" android:includeFontPadding="true" android:paddingLeft="8dp" android:paddingRight="8dp" android:paddingTop="4dp" android:paddingBottom="6dp" android:lineSpacingExtra="4dp" android:text="@string/keyboard_hint" android:textSize="12sp" android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- 2026-07-11 — clipChildren false so 3D near-edge can overshoot without a flat top crop. -->
    <FrameLayout
        android:id="@+id/layout_player_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone">
        <ImageView android:id="@+id/iv_player_bg_blur" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:background="@android:color/transparent"/>
        <!-- 2026-07-11 — Scrim only for album-blur; theme NP wallpaper stays undarkened (editor parity). -->
        <View android:id="@+id/player_bg_scrim" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#44000000" android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/player_content_row"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="top"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingTop="@dimen/y1_status_bar_height"
            android:paddingBottom="@dimen/y1_player_transport_height"
            android:paddingLeft="@dimen/y1_player_content_pad_left"
            android:paddingRight="0dp">

            <!-- 2026-07-11 — Art slot extends 14dp into status pad; cover at +14 aligns with info. -->
            <FrameLayout
                android:id="@+id/player_album_container"
                android:layout_width="@dimen/y1_player_art_width"
                android:layout_height="@dimen/y1_player_art_slot_height"
                android:layout_marginTop="-14dp"
                android:layout_gravity="top"
                android:clipChildren="false"
                android:clipToPadding="false">
                <ImageView
                    android:id="@+id/iv_album_art"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/y1_player_art_cover_height"
                    android:layout_marginTop="@dimen/y1_player_art_top_overshoot"
                    android:layout_gravity="top"
                    android:scaleType="centerCrop"
                    android:src="@drawable/default_album"
                    android:background="#222222" />
                <com.solar.launcher.flow.PlayerAlbumArt3dView
                    android:id="@+id/iv_album_art_3d"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />
                <ImageView
                    android:id="@+id/iv_pause_overlay"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/y1_player_art_top_overshoot"
                    android:src="@android:drawable/ic_media_pause"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- 2026-07-11 — Info = 235×225; padTop so title isn't flush; width fills theme box. -->
            <LinearLayout
                android:id="@+id/player_info_column"
                android:layout_width="@dimen/y1_player_info_width"
                android:layout_height="@dimen/y1_player_info_height"
                android:layout_marginLeft="@dimen/y1_player_info_margin_left"
                android:layout_gravity="top"
                android:orientation="vertical"
                android:paddingTop="8dp">
                <TextView android:id="@+id/tv_player_title" android:layout_width="match_parent" android:layout_height="36dp" android:text="@string/common_title" android:textColor="#FFFFFF" android:textSize="25sp" android:textStyle="bold" android:gravity="start|center_vertical" android:paddingLeft="13dp" android:singleLine="true" android:ellipsize="marquee" android:background="#1affffff"/>
                <TextView android:id="@+id/tv_player_artist" android:layout_width="match_parent" android:layout_height="38dp" android:layout_marginTop="8dp" android:text="@string/common_artist" android:textColor="#FFFFFF" android:textSize="21sp" android:textStyle="bold" android:gravity="start|center_vertical" android:paddingLeft="13dp" android:singleLine="true" android:ellipsize="marquee" android:background="#1affffff"/>
                <TextView android:id="@+id/tv_player_album" android:layout_width="match_parent" android:layout_height="38dp" android:layout_marginTop="8dp" android:text="" android:textColor="#FFFFFF" android:textSize="21sp" android:textStyle="bold" android:gravity="start|center_vertical" android:paddingLeft="13dp" android:singleLine="true" android:ellipsize="marquee" android:background="#1affffff"/>
                <TextView android:id="@+id/tv_player_track_count" android:layout_width="match_parent" android:layout_height="38dp" android:layout_marginTop="8dp" android:text="— / —" android:textColor="#FFFFFF" android:textSize="21sp" android:textStyle="bold" android:gravity="start|center_vertical" android:paddingLeft="13dp" android:singleLine="true" android:background="#1affffff"/>
                <LinearLayout android:id="@+id/player_status_row" android:layout_width="match_parent" android:layout_height="35dp" android:layout_marginTop="8dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingLeft="13dp" android:background="#1affffff">
                    <ImageView android:id="@+id/iv_player_shuffle_status" android:layout_width="24dp" android:layout_height="24dp" android:visibility="gone" android:layout_marginRight="10dp"/>
                    <ImageView android:id="@+id/iv_player_repeat_status" android:layout_width="24dp" android:layout_height="24dp" android:visibility="gone"/>
                </LinearLayout>
                <FrameLayout
                    android:id="@+id/player_lyrics_panel"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="0dp"
                    android:visibility="gone"
                    android:background="#1affffff">
                    <ListView
                        android:id="@+id/player_lyrics_list"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:divider="@android:color/transparent"
                        android:dividerHeight="4dp"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:scrollbars="none" />
                    <TextView
                        android:id="@+id/player_lyrics_plain"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:paddingTop="4dp"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/player_visualizer_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="@dimen/y1_status_bar_height"
            android:paddingBottom="@dimen/y1_player_transport_height"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_viz_title"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:background="#1affffff"
                android:ellipsize="marquee"
                android:gravity="center_vertical"
                android:marqueeRepeatLimit="marquee_forever"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:singleLine="true"
                android:text="@string/common_title"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_viz_artist"
                android:layout_width="match_parent"
                android:layout_height="22dp"
                android:layout_marginTop="3dp"
                android:background="#1affffff"
                android:ellipsize="marquee"
                android:gravity="center_vertical"
                android:marqueeRepeatLimit="marquee_forever"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:singleLine="true"
                android:text="@string/common_artist"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_viz_album"
                android:layout_width="match_parent"
                android:layout_height="22dp"
                android:layout_marginTop="3dp"
                android:background="#1affffff"
                android:ellipsize="marquee"
                android:gravity="center_vertical"
                android:marqueeRepeatLimit="marquee_forever"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:singleLine="true"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_viz_track_count"
                android:layout_width="match_parent"
                android:layout_height="22dp"
                android:layout_marginTop="4dp"
                android:background="#1affffff"
                android:gravity="center_vertical"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:singleLine="true"
                android:text="00 / 00"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <FrameLayout
                android:id="@+id/player_lyrics_viz_panel"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="4dp"
                android:visibility="gone"
                android:background="#1affffff">
                <ListView
                    android:id="@+id/player_lyrics_viz_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="2dp"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:scrollbars="none" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/player_visualizer_slot"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- 2026-07-11 — Match transport height to bottom chrome band (times/scrub sit inside). -->
        <include
            android:id="@+id/player_transport_bar"
            layout="@layout/layout_media_transport_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/y1_player_transport_height"
            android:layout_gravity="bottom" />
    </FrameLayout>

    <RelativeLayout
        android:id="@+id/layout_status_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/y1_status_bar_height"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:background="#00000000">

        <TextView
            android:id="@+id/tv_status_clock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_toLeftOf="@+id/pb_status_loading"
            android:layout_marginRight="6dp"
            android:layout_centerVertical="true"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true"
            android:text="12:00 AM"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 2026-07-15 — Search throbber; never focusable (A5 DPAD must stay on menus/modals). -->
        <!-- 2026-07-18 — Spin 2× stock (indeterminateDuration 2000 vs framework 4000) for
             snappier waits and clearer lockup tells when the spinner freezes. -->
        <ProgressBar
            android:id="@+id/pb_status_loading"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_toLeftOf="@+id/status_bar_icons"
            android:layout_centerVertical="true"
            android:layout_marginRight="8dp"
            android:visibility="gone"
            android:indeterminate="true"
            android:indeterminateDuration="2000"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:importantForAccessibility="no" />

        <LinearLayout
            android:id="@+id/status_bar_icons"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView android:id="@+id/iv_status_headphone" android:layout_width="@dimen/y1_status_icon_size" android:layout_height="@dimen/y1_status_icon_size" android:src="@drawable/ic_headphone" android:visibility="gone" android:scaleType="fitCenter" android:layout_marginRight="6dp"/>
            <ImageView android:id="@+id/iv_status_wifi" android:layout_width="@dimen/y1_status_icon_size" android:layout_height="@dimen/y1_status_icon_size" android:src="@drawable/ic_wifi" android:visibility="gone" android:scaleType="fitCenter" android:layout_marginRight="6dp"/>
            <ImageView android:id="@+id/iv_status_bluetooth" android:layout_width="@dimen/y1_status_icon_size" android:layout_height="@dimen/y1_status_icon_size" android:src="@drawable/ic_bluetooth" android:visibility="gone" android:scaleType="fitCenter" android:layout_marginRight="6dp"/>
            <ImageView android:id="@+id/iv_status_battery" android:layout_width="wrap_content" android:layout_height="@dimen/y1_battery_icon_height" android:adjustViewBounds="true" android:scaleType="fitCenter" android:visibility="gone" android:layout_marginRight="4dp"/>
            <TextView android:id="@+id/tv_status_battery" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/layout_brightness_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="30dp"
        android:background="#00000000"
        android:visibility="gone"
        android:gravity="center">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/player_brightness_header" android:textColor="#BBFFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="30dp" android:visibility="gone"/>
        <ProgressBar android:id="@+id/pb_brightness" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="20dp" android:max="255" android:layout_marginBottom="15dp"/>
        <TextView android:id="@+id/tv_brightness_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_brightness_hint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/player_brightness_hint" android:textSize="14sp" android:layout_marginTop="30dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_storage_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="30dp"
        android:background="#00000000"
        android:visibility="gone"
        android:gravity="center">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/player_storage_header" android:textColor="#BBFFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="30dp" android:visibility="gone"/>
        <ProgressBar android:id="@+id/pb_storage" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="20dp" android:layout_marginBottom="15dp"/>
        <TextView android:id="@+id/tv_storage_details" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/player_storage_used" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_storage_hint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/player_storage_back_hint" android:textSize="14sp" android:layout_marginTop="30dp"/>    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_webserver_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="30dp"
        android:background="#00000000"
        android:visibility="gone"
        android:gravity="center">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/webserver_header" android:textColor="#BBFFFFFF" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="40dp" android:visibility="gone"/>
        <TextView android:id="@+id/tv_server_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/webserver_stopped_icon" android:textColor="#FF5555" android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="10dp"/>
        <TextView android:id="@+id/tv_server_ip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/webserver_ip_placeholder" android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="24dp"/>
        <Button android:id="@+id/btn_server_toggle" android:layout_width="match_parent" android:layout_height="@dimen/y1_menu_item_height" android:text="@string/webserver_start" android:background="@android:color/transparent" android:layout_marginBottom="16dp" android:focusable="true"/>
        <TextView android:id="@+id/tv_webserver_hint" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/webserver_hint" android:textSize="16sp" android:gravity="center"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layout_video_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:visibility="gone">

        <!-- 2026-07-15 — Host centers letterboxed SurfaceRenderView (Gravity.CENTER). -->
        <FrameLayout
            android:id="@+id/video_surface_host"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Calm load/buffer status over the picture (Hallmark: honest progress, not “Resolving…”). -->
        <TextView
            android:id="@+id/tv_video_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:textColor="#EEFFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:visibility="gone" />

        <include
            android:id="@+id/video_transport_bar"
            layout="@layout/layout_media_transport_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/layout_photo_viewer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_photo_viewer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" />
    </FrameLayout>

    <include layout="@layout/layout_flow_mode" />

    <!-- 2026-07-11 — A5 portrait bottom info strip (marquee explainers); GONE on Y1/Y2. -->
    <LinearLayout
        android:id="@+id/layout_a5_bottom_info"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:background="#CC111111"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_a5_strip_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_a5_strip_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_a5_strip_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>


    <!-- 2026-07-18 — Lalal Stem Player full-screen host (Activity rings UI). -->
    <FrameLayout
        android:id="@+id/layout_stem_player"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:background="#FF0A0A0C" />

</FrameLayout>