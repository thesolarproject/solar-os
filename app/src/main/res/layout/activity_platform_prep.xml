<?xml version="1.0" encoding="utf-8"?>
<!-- 2026-07-05 — Blocking platform prep wizard (wheel-friendly full screen). -->
<!-- 2026-07-16 — Full black “getting ready” face so first boot is never a blank screen. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/platform_prep_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF000000"
    android:gravity="center_horizontal"
    android:padding="16dp">

    <TextView
        android:id="@+id/platform_prep_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/platform_prep_title"
        android:textColor="#FFFFFFFF"
        android:textSize="18sp"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/platform_prep_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/platform_prep_subtitle"
        android:textColor="#FFCCCCCC"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <ProgressBar
        android:id="@+id/platform_prep_spinner"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp" />

    <ProgressBar
        android:id="@+id/platform_prep_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="0"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/platform_prep_percent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0%"
        android:textColor="#FFAAAAAA"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <ScrollView
        android:id="@+id/platform_prep_log_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:visibility="gone">

        <TextView
            android:id="@+id/platform_prep_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF888888"
            android:textSize="12sp" />
    </ScrollView>

    <Button
        android:id="@+id/platform_prep_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:text="@string/platform_prep_continue" />
</LinearLayout>
