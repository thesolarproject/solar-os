<?xml version="1.0" encoding="utf-8"?>
<!-- 2026-07-05 — Shared full-screen wheel keyboard (Solar app + system IME overlay). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_solar_wheel_keyboard"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal|top"
    android:paddingTop="@dimen/y1_status_bar_height"
    android:paddingLeft="15dp"
    android:paddingRight="15dp"
    android:paddingBottom="8dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="#00000000">

    <TextView
        android:id="@+id/tv_keyboard_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tv_keyboard_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/y1_menu_item_height"
        android:text=""
        android:textSize="@dimen/y1_menu_text_size"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_key_pprev"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="@dimen/y1_menu_text_size" />

        <TextView
            android:id="@+id/tv_key_prev"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="@dimen/y1_menu_text_size" />

        <TextView
            android:id="@+id/tv_key_current"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="@dimen/y1_menu_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_key_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="@dimen/y1_menu_text_size" />

        <TextView
            android:id="@+id/tv_key_nnext"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="@dimen/y1_menu_text_size" />
    </LinearLayout>

    <!-- 2026-07-18 — Legend + vertical pad so ImageSpan Back/cancel never clips. -->
    <!-- 2026-07-18 — clipToPadding false + extra line gap so wide PP/Prev glyphs stay whole. -->
    <TextView
        android:id="@+id/tv_keyboard_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:includeFontPadding="true"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:lineSpacingExtra="6dp"
        android:lineSpacingMultiplier="1.1"
        android:text="@string/keyboard_hint"
        android:textSize="12sp"
        android:layout_marginTop="8dp" />
</LinearLayout>
