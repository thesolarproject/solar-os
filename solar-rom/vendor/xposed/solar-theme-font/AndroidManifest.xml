<?xml version="1.0" encoding="utf-8"?>
<!-- System-wide Solar theme font via Xposed (Y1 API 17 + Y2 API 19). -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.solar.launcher.xposed.themefont"
    android:versionCode="1"
    android:versionName="1.0">

    <uses-sdk android:minSdkVersion="17" android:targetSdkVersion="19" />

    <application android:label="Solar Theme Font" android:hasCode="true">
        <meta-data android:name="xposedmodule" android:value="true" />
        <meta-data android:name="xposeddescription"
            android:value="Apply Solar theme font system-wide (reads /.solar/system-font.ttf)" />
        <meta-data android:name="xposedminversion" android:value="54" />
    </application>
</manifest>
