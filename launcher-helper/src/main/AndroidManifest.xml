<?xml version="1.0" encoding="utf-8"?>
<!-- 2026-07-06 — Permanent Android HOME middle-man; routes to Solar/Rockbox/JJ/custom. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.GET_TASKS" />

    <application
        android:allowBackup="false"
        android:icon="@android:drawable/ic_menu_compass"
        android:label="@string/helper_app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">

        <activity
            android:name=".LauncherHomeActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LauncherPickerActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar" />

        <activity
            android:name=".HomeTargetGraceActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.DeviceDefault.NoActionBar" />

        <activity
            android:name=".LauncherSwitchPromptActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <service
            android:name=".LauncherEnforcerService"
            android:exported="false"
            android:process=":watchdog" />

        <receiver
            android:name=".HelperShowLauncherPickerReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.solar.launcher.homehelper.action.SHOW_LAUNCHER_PICKER" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".SetHomeTargetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.solar.launcher.homehelper.action.SET_HOME_TARGET" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".LauncherSwitchReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.solar.launcher.homehelper.action.APPLY_HOME_TARGET" />
                <action android:name="com.solar.launcher.homehelper.action.RESTART_ACTIVE_LAUNCHER" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".HelperBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
