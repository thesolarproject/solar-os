+
+    boolean moveToFirst();
+
+    boolean moveToNext();
+
+    long getLong(int columnIndex);
+
+    int getInt(int columnIndex);
+
+    String getString(int columnIndex);
+
+    boolean isNull(int columnIndex);
+
+    int getColumnIndex(String columnName);
+
+    void close();
+
+    boolean isClosed();
